# Supabase — get these from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# No API key needed for the map — it uses OpenStreetMap (free, no account required).
# Geocoding also uses OpenStreetMap's Nominatim API (free, no account required).
